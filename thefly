cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/fly
############ fly ##########
# Author: Franck Jouvanceau
###########################
[ "$1" != source ] && unset _fly_loaded
[ "$_fly_loaded" ] && return
: "${FLY_MSG:=Bzzz Bzzz !!!}"
_fly_loaded=1
: "${FLY_HOME:=$HOME}"
export FLY_HOME
: "${FLY_RC:=$HOME/.flyrc}"
: "${_fly_github:=https://github.com}"
: "${_fly_githubraw:=https://raw.githubusercontent.com}"
: "${_fly_gitrepo:=joknarf/thefly}"
: "${FLY_TMPDIR:=/tmp}"
: "${FLY_HISTFILE:=$HOME/.fly_history}"
: "${FLY_TARZ:=-z}"
: "${_fly_uuid:=$(cat "$FLY_HOME/.fly.d/.flyuuid" 2>/dev/null || uuidgen)}"
_fly_lib="$FLY_HOME/.fly.d/.fly.lib"
. "$_fly_lib/.fshell"
alias fly=". $FLY_HOME/.fly.d/fly"
. "$_fly_lib/aliases"

[ "$_fly_lock" ] && trap 'flock -u 4' TERM

type whence >/dev/null 2>&1 || whence() { type -p "$@"; }
read _fly_sqlite <<<"$(whence sqlite3 sqlite)"
read _fly_tar <<<"$(whence gtar gnutar tar)"
: "${_fly_tar:=tar}"
[[ "$($_fly_tar --version 2>/dev/null)" = *box* ]] && {
    _fly_taropts=( --exclude=.git --exclude=.github --exclude=.gitignore )
} || _fly_taropts=( --no-xattrs --exclude-vcs )

function _fly_package
{
    [ "$FLY_RC" ] && [ -r "$FLY_RC" ] && cp "$FLY_RC" "$_fly_lib"
    $_fly_tar -cf - -C "$FLY_HOME" "$_fly_tarz" "${_fly_taropts[@]}" --exclude=README.md --exclude='plugins/*/.*' --exclude '*/*/tests' .fly.d
}

function _fly_xpretar
{
    printf 'FLY_HOME="%s"\n' "$_fly_tmpdir"
    cat - <<'EOF'
(umask 077;mkdir -p "$FLY_HOME")
! chmod 700 "$FLY_HOME" && echo "Not owner of $FLY_HOME. Abort" >&2 && exit 1
type gtar >/dev/null 2>&1 && tar=gtar || tar=tar
exec 4<>"$FLY_HOME/.fly.lock"
flock 4 2>/dev/null && export _fly_lock=1
rm -rf "$FLY_HOME/.fly.d"
EOF
}

function _fly_xpackage
{   
    printf '$tar -xmf - -C "$FLY_HOME" %s --no-same-owner' "$_fly_tarz"
}

function _fly_sudo
{
    typeset user="${1:--}" e sopt=(--)
    [ "$user" = '-' ] || sopt=(-u "$user")
    [ "$1" ] && shift
    \cd /
    sudo "${sopt[@]}" '/bin/sh' <<<"$(_fly_pkg_warp "$@")"; e=$?
    \cd "$OLDPWD"
    return $e
}

function _fly_in
{
    typeset container="$1" copt=(-it) cmd
    [[ $container = *@* ]] && copt+=(-u "${container%%@*}")
    container="${container#*@}"
    read cmd <<<"$(whence podman docker)"
    [ "$cmd" ] || return 1
    shift
    "$cmd" exec "${copt[@]}" "$container" /bin/sh -c "$(_fly_pkg_warp "$@")"
}

function _fly_ssh_ok
{
    typeset ssh_ver ssh_maj ssh_min r
    _fly_ssh_ok=false
    type ssh >/dev/null 2>&1 || return
    read -r ssh_ver r <<<"$(ssh -V 2>&1)"
    ssh_ver="${ssh_ver#*_}";ssh_ver="${ssh_ver%p*}"
    IFS='.' read -r ssh_maj ssh_min r <<<"$ssh_ver"
    [ "$ssh_maj" -gt 8 ] && _fly_ssh_ok=true && return
    # ssh 8.0 RemoteCommand buffer too short
    [ "$ssh_maj" = 8 ] && [ "$ssh_min" -gt 0 ] && _fly_ssh_ok=true
    return 0
}

function _fly_package_zfx
{
    typeset b64opt
    base64 -w0 <<<ok >/dev/null 2>&1 && b64opt='-w0'
    cat - <<EOF
$(_fly_xpretar);echo "$(_fly_package |base64 $b64opt)"|base64 -d|$(_fly_xpackage)
EOF
}

function _fly_pack
{
    cat - <<EOF
[ "\$_fly_lock" ] && return
[ "\$1" = install ] && FLY_HOME="\$HOME" || $(_fly_package_zfx)
[[ "\$1" = *sh ]] && _fly_destshell="\$1" && shift
. "\$FLY_HOME/.fly.d/fly" \${1:-loginshell}
EOF
}

function _fly_pkg_login
{
    cat - <<EOF
_fly_destshell="$_fly_destshell"
FLY_ETC_RC="$FLY_ETC_RC"
FLY_USER_RC="$FLY_USER_RC"
_fly_cmd="$([ "$1" ] && printf '%q ' "$@" |base64 -w 0)"
. "\$FLY_HOME/.fly.d/.fly.lib/.loginshell"
EOF
}

function _fly_pkg_warp
{
    _fly_package_zfx
    _fly_pkg_login "$@"
}

function _fly_hist_init
{
    [ "$FLY_HISTFILE" ] || return 1
    [ "$_fly_sqlite" ] || return 1
    [ -f "$FLY_HISTFILE" ] || (
        umask 0077
        "$_fly_sqlite" "$FLY_HISTFILE" '
          CREATE TABLE flyto (params PRIMARY KEY, begin datetime, end datetime, sudo_user, exit_code INTEGER, hostname, user, alias);
          CREATE INDEX idx_begin ON flyto(begin);
        ' 2>/dev/null
    ) || return 1
}

function _fly_hist_migr
{
   _fly_hist_init || return 1
   "$_fly_sqlite" "$FLY_HISTFILE" 'ALTER TABLE flyto add alias' 2>/dev/null
}

function _fly_sql_parse
{
    awk -F'|' '
      {for(i=1;i<=NF;i++) {if (length($i)>mw[i]) mw[i]=length($i);it[NR,i]=$i}}
      END{
        for(i=1;i<=NR;i++) {
          printf("%s%s", it[i,1], sep)
          for(j=2;j<=NF;j++) printf("%-*s ", mw[j], it[i,j])
          printf("\n")
        }
      }
    ' sep="$1"
}

function _fly_hist_list {
    _fly_hist_init || return
    typeset filter="$1";shift
    "$_fly_sqlite" "$@" "$FLY_HISTFILE" "SELECT params, alias, strftime('%Y-%m-%d %H:%M',begin) AS start, user||'@'||hostname AS host, exit_code AS e, sudo_user AS s FROM flyto WHERE params LIKE '$filter%' ORDER BY begin DESC" 2>/dev/null || _fly_hist_migr
}

function _fly_hist_del {
    _fly_hist_init || return
    typeset q=$'\'' params="${1//$q/$q$q}"
    "$_fly_sqlite" "$FLY_HISTFILE" "DELETE FROM flyto WHERE params='$params'" 2>/dev/null
}

function _fly_hist {
    _fly_hist_list "$1"| _fly_sql_parse "$2"
}

_fly_hist_key() {
    # F8 Ctl-D Del
    case "$1" in
        '[19~'|$'\x04'|'[3~') _fly_hist_del "${item%%$'\t'*}";;
    esac
    return 2
}

function flyto_history {
    [ "$SELECTOR_CASEI" ] && {
        typeset s
        selector -i "$(_fly_hist "$1" $'\t')" -m 10 -k _fly_hist_key >/dev/null
        s="$selected";unset selected
        [ "$s" ] || return 0
        echo "flyto $s" >&2
        eval _fly_ssh "$s"; return $?
    }
    _fly_hist_list "$1" -column -header
}

function _fly_ssh
{
    _fly_hist_add()
    {
        typeset hostname user aliasupd
        _fly_hist_init || return
        read hostname user <<<"$(ssh -G "${ssh_args[@]}" "${ssh_argc[@]}" 2>/dev/null | awk '/^hostname /{h=$2} /^user /{u=$2} h && u {exit} END{print h, u}')"
        [ "$halias" ] && aliasupd=", alias='$halias'"
        "$_fly_sqlite" "$FLY_HISTFILE" "INSERT OR IGNORE INTO flyto (params) VALUES ('$params');
        UPDATE flyto set begin=datetime('now','localtime'), sudo_user='$SUDO_USER', hostname='$hostname', user='$user' $aliasupd where params='$params';" 2>/dev/null || _fly_hist_migr
    }
    _fly_hist_end()
    {
        _fly_hist_init || return
        "$_fly_sqlite" "$FLY_HISTFILE" "UPDATE flyto SET end=datetime('now','localtime'), exit_code=$e WHERE params='$params'" 2>/dev/null
    }
    _ssh2()
    {
        _fly_package | ssh -o LogLevel=Error "${ssh_args[@]}" "${ssh_argc[@]}" "/bin/sh -c '$(_fly_xpretar);$(_fly_xpackage)'" || return $?
        ssh "${ssh_args[@]}" "${ssh_argc[@]}" -t "exec /bin/sh -c 'FLY_HOME=\"$_fly_tmpdir\";$(_fly_pkg_login "${fly_cmd[@]}")'"
        e=$?
        _fly_hist_end
    }
    typeset cmd ssh_args=() ssh_config ssh_argc=() fly_cmd e params q=$'\'' halias
    set -A ssh_args 2>/dev/null;set -A ssh_argc 2>/dev/null
    while [ "$1" ];do
        case "$1" in
        --usage|-V) ssh "$1"; return $?;;
        -F)  shift; ssh_config="$1"; ssh_argc=(-F "$1");;
        -*F) ssh_args+=("${1%F}");shift;ssh_config="$1";ssh_argc=(-F "$1");;
        -F*) ssh_config="Include ${1#-F}"; ssh_argc=("$1");;
        -*F*) ssh_args+=("${1%%F*}");ssh_config="${1#-*F}";ssh_argc=(-F "${1#-*F}");;
        --)  shift && fly_cmd=("$@"); break;;
        *#*) halias="${1#*#}"; ssh_args+=("${1%#*}");;
        *)   ssh_args+=("$1");;
        esac
        shift
    done
    params="$(printf '%q ' "${ssh_args[@]}" "${ssh_argc[@]}")";params="${params% }"
    params="${params//$q/$q$q}";
    _fly_hist_add
    cmd="exec /bin/sh -c '$(_fly_pkg_warp "${fly_cmd[@]}")'"
    cmd="${cmd//$'\n'/;}"
    [ "$_fly_ssh_ok" ] || _fly_ssh_ok
    $_fly_ssh_ok && [ ${#cmd} -lt 130000 ] || { _ssh2 ; return $e; } 
    if [ "$ssh_config" ] ;then
         [[ $ssh_config = /* ]] || ssh_config="$PWD/$ssh_config"
         ssh_config="Include $ssh_config"
    else
         [ -f ~/.ssh/config ] && ssh_config="Include $HOME/.ssh/config"
    fi
    cat - <<_EOF_ >"$FLY_HOME/.fly.ssh"
RequestTTY yes
RemoteCommand $cmd
$ssh_config
_EOF_
    \cd "$FLY_HOME";ssh -F .fly.ssh "${ssh_args[@]}";e=$?;\cd "$OLDPWD"
    _fly_hist_end
    return $e
}


function _fly
{
    typeset plugin submodule
    _fly_tmpdir="$FLY_TMPDIR/.fly.\`id -u\`/$_fly_uuid"
    _fly_tarz="$FLY_TARZ"
    case "$1" in
        list)
            (\cd "$FLY_HOME/.fly.d/plugins" && printf '%s\n' */*.plugin."${FLY_SHELL##*/}")
        ;;
        shell)
            shift
            [ "$1" ] && ! type "$1" >/dev/null 2>&1 && echo "Cannot find shell $1" >&2 && return 1
            unset _fly_fish
            _fly_destshell="${1:-$FLY_SHELL}" exec /bin/sh -c ". $_fly_lib/.loginshell"
        ;;
        ssh|to) 
            shift
            [ "${1:--H}" = -H ] && { flyto_history "$2"; return $?; }
            _fly_ssh "$@"
            return $?
        ;;
        sudo|as) 
            shift;
            [ "$_fly_destshell" ] && ! type "$_fly_destshell" >/dev/null 2>&1 && echo "Cannot find shell $2" >&2 && return 1
            _fly_sudo "$@"
            return $?
        ;;
        in)
            shift;
            _fly_tarz='-z'
            _fly_in "$@"
            return $?
        ;;
        pack)
            shift
            _fly_pack
        ;;
        *) echo "unknown option, use 'fly help'";return 1;;
    esac
}

function _fly_cleanup
{
    [ -d "$1" ] || return 0
    [ "$(\cd "$1";pwd -P)" = "$(\cd "$HOME";pwd -P)" ] && return 0
    flock -n 5 && flock "$1/.fly.lock" rm -rf "$1"/.fly.* && rmdir "$1" "${1%/*}" 2>/dev/null
}

case "$1" in
    help)  cat "$_fly_lib/usage";;
    login)      
        shift 
        echo "$FLY_MSG" >&2
        \cd /;\cd
        . "$_fly_lib/.login.${FLY_SHELL##*/}"
        . "$_fly_lib/.source_plugins"
        [ "$_fly_cmd" ] && {
          _fly_cmd="$(base64 -d <<<"$_fly_cmd")" || exit 1
          eval "cmd=($_fly_cmd)"
          [ "$_fly_lock" ] && flock -u 4
          [ "${#cmd[@]}" = 1 ] && ! type "$cmd" >/dev/null 2>&1 && { . <(printf %s "$cmd"); e=$?; } || { eval "${cmd[@]}"; e=$?; }
          _fly_cleanup "$_fly_share"
          exit "$e"
        }
        unset FLY_ETC_RC FLY_USER_RC
    ;;
    loginshell|install)
        export _fly_destshell FLY_ETC_RC FLY_USER_RC
        exec /bin/sh -c ". $_fly_lib/.loginshell"
    ;;
    source|activate)
        shift
        [ "$_fly_fish" ] && return
        . "$_fly_lib/.source_plugins" "$1"
    ;;
    add)
        shift
        [ -d "$FLY_HOME/.fly.d/.git" ] && {
            (\cd "$FLY_HOME/.fly.d" && git submodule add "$_fly_github/$1" "plugins/${1##*/}" 2>/dev/null)
        } || (\cd "$FLY_HOME/.fly.d/plugins" && git clone "$_fly_github/$1" -q >/dev/null)
        (\cd "$FLY_HOME/.fly.d" && git config -f ".gitmodules submodule.plugins/${1##*/}.shallow" true >/dev/null 2>/dev/null)
        ln -s "../plugins/${1##*/}" "$FLY_HOME/.fly.d/plugins.d/50-${1##*/}"
        set --
        [ "$_fly_fish" ] || . "$_fly_lib/.source_plugins" "${1#*/}"
        :
    ;;
    del)
        shift
        [ ! "$1" ] && echo "usage: fly del <plugin>" >&2 && return 1
        [ ! -d "$FLY_HOME/.fly.d/plugins/${1##*/}" ] && echo "plugin ${1##*/} not found" >&2 && return 1
        [ -d "$FLY_HOME/.fly.d/.git" ] && {
            (\cd "$FLY_HOME/.fly.d" && git submodule deinit -f "plugins/${1##*/}" && \
                git add .gitmodules
                git rm --cached "plugins/${1##*/}"
                git config -f .gitmodules --remove-section "submodule.plugins/${1##*/}"
            ) 2>/dev/null
        } 
        rm -rf "$FLY_HOME/.fly.d/plugins/${1##*/}" "$FLY_HOME/.fly.d/.git/modules/plugins/${1##*/}" "$FLY_HOME/.fly.d/plugins.d/"??-"${1##*/}"
    ;;
    update)
        shift
        [ ! "$1" ] && echo "usage: fly update <plugin>" >&2 && return 1 
        (\cd "$FLY_HOME/.fly.d/plugins/${1#*/}" && git pull origin "$(git rev-parse --abbrev-ref HEAD)")
        [ "$_fly_fish" ] || . "$_fly_lib/.source_plugins" "${1#*/}"
    ;;
    updateall)
        shift
        for plugin in "$FLY_HOME/.fly.d/plugins"/*/.git ;do
            [ -d "$plugin" ] && (\cd "$plugin/.." && git pull origin "$(git rev-parse --abbrev-ref HEAD)")
            [ -s "$plugin" ] && submodule=1
        done
        [ "$submodule" ] && (\cd "$FLY_HOME/.fly.d" && {
            git submodule update --remote --merge 2>/dev/null
            git submodule foreach git pull 2>/dev/null
        })
        unset plugin submodule
        [ "$_fly_fish" ] || . "$_fly_lib/.source_plugins"
    ;;
    upgrade)
        shift
        . <(curl -s -L -H 'Pragma: no-cache' -H 'Cache-Control: no-cache' "$_fly_githubraw/$_fly_gitrepo/main/thefly") install
    ;;
esac

[ "$_fly_lock" ] && trap - TERM && flock -u 4 && exec 4<&- # unlock teleportation
[ "$_fly_share" ] && trap "_fly_cleanup '$_fly_share'" EXIT
unset _fly_share _fly_lock _fly_destshell
:
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/fly.fish
if test (count $argv) -gt 0 -a "$argv[1]" != source
    set -e _fly_loaded
end
if not set -q _fly_loaded

not set -q FLY_MSG && set -x FLY_MSG "Bzzz Bzzz !!!"
echo $FLY_MSG >&2
set -x _fly_loaded 1

not set -q FLY_HOME && set -x FLY_HOME $HOME
not set -q FLY_RC && set -x FLY_RC "$HOME/.flyrc"
not set -q FLY_TMPDIR && set -x FLY_TMPDIR /tmp
not set -q _fly_uuid && set -x _fly_uuid (cat "$FLY_HOME/.fly.d/.flyuuid" 2>/dev/null; or uuidgen)
set -x _fly_lib $FLY_HOME/.fly.d/.fly.lib
set -x FLY_SHELL fish 
set -x _fly_fish true

test -n "$_fly_lock" && trap 'flock -u 4 2>/dev/null' TERM

switch "$argv[1]"
    case source activate
        source $_fly_lib/.source_plugins.fish
    case login
        . $_fly_lib/.login.fish
        . $_fly_lib/.source_plugins.fish
end
test -n "$_fly_lock" && trap - TERM && flock -u 4 2>/dev/null #fish cannot close fd...
set -e _fly_lock
test -n "$_fly_share" && trap "flock -n 5 && flock '$_fly_share/.fly.lock' rm -rf '$_fly_share'/.fly.* && rmdir '$_fly_share' 2>/dev/null" EXIT
set -e _fly_share

function fly
   FLY_HOME="$FLY_HOME" bash -c 'args=("$@");. $FLY_HOME/.fly.d/fly "${args[@]}"' _ $argv
end

function _fly
   FLY_HOME="$FLY_HOME" bash -c 'args=("$@");. $FLY_HOME/.fly.d/fly;_fly "${args[@]}"' _ $argv
end

alias fly.fish='. $FLY_HOME/.fly.d/fly.fish'

. $_fly_lib/aliases
end # fish cannot return...
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/_fly_
#compdef _fly
function _fly_ {
  local -a commands containers
  local COMPADD_ARGS=(-Q)
  case "${words[2]}" in
    ssh)
      commands=(
        "${(@f)$(_fly_hist "$words[$CURRENT]" ':')}"
      )
      _describe -t commands 'flyto command' commands
    ;;
    sudo) [ "$CURRENT" = 3 ] && _users
    ;;
    in)  [ "$CURRENT" = 3 ] || return
      containers=(${(f)"$(docker ps --format '{{.Names}}' 2>/dev/null)"})
      compadd -- $containers
    ;;
  esac
}
FLY_EOF

)
base64 -d <<<''
$_fly_sourced && . $FLY_HOME/.fly.d/fly activate
: