cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.login.fish
cd /;cd
# TODO: spawn with fish -N to manage FLY_ETC_RC/FLY_USER_RC
# for i in /etc/fish/conf.d/*.fish ~/.config/fish/conf.d/*.fish /etc/fish/config.fish ~/.config/fish/config.fish
#   test -f $i && . $i
# end
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.login.ksh
typeset +x ENV
ENV=~/.kshrc
#alias typeset="typeset +r"
#alias readonly=typeset
alias _src_etc_profile_d='true' # rhel
$FLY_ETC_RC && . /etc/profile
\cd
[ -r .profile ] && $FLY_USER_RC && . ./.profile
[ -r "$ENV" ] && $FLY_USER_RC && . "$ENV"
#unalias typeset readonly
unalias _src_etc_profile_d
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.login.zsh
ZDOTDIR=~/
\cd
for i in zshenv zprofile zshrc;do
    [ -r "/etc/zsh/$i" ] && "$FLY_ETC_RC" && . "/etc/zsh/$i"
    [ -r ".$i" ] && "$FLY_USER_RC" && . "./.$i"
done
unset i
#typeset +r PS1
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.loginshell
## /!\ sourced by /bin/sh
FLY_ETC_RC="${FLY_ETC_RC:-true}"
FLY_USER_RC="${FLY_USER_RC:-true}"
export FLY_HOME FLY_ETC_RC FLY_USER_RC _fly_cmd
\cd "$FLY_HOME/.fly.d/.fly.lib"
. ./.fshell
[ ! -t 0 ] && [ -t 1 ] && exec <&1
[ "$FLY_HOME" = "$HOME" ] || {
  exec 5<>"$FLY_HOME/.fly.share"
  flock -s 5 2>/dev/null && export _fly_share="$FLY_HOME"
}
case "$FLY_SHELL" in
    *bash) PS1="" exec $FLY_SHELL --rcfile ".bashrc";;
    *zsh)  ZDOTDIR=$FLY_HOME/.fly.d/.fly.lib exec $FLY_SHELL -d;;
    *ksh)  export ENV=$FLY_HOME/.fly.d/.fly.lib/.login; exec $FLY_SHELL;;
    *fish) exec $FLY_SHELL -C ". .fishrc";;
esac
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.source_plugins
[ "$1" ] && _fly_p="/$1" || _fly_p=""
_fly_shell="${FLY_SHELL##*[/\\]}"
set --
[ -r "$FLY_HOME/.fly.d/.flyrc" ] && . "$FLY_HOME/.fly.d/.flyrc"
[ -r "$FLY_HOME/.fly.d/.${_fly_shell}rc" ] && . "$FLY_HOME/.fly.d/.${_fly_shell}rc"
$FLY_USER_RC && [ "$FLY_RC" ] && [ -r "$FLY_RC" ] && cp "$FLY_RC" "$_fly_lib"
[ "$FLY_RC" ] && [ -r "$_fly_lib/${FLY_RC##*/}" ] && . "$_fly_lib/${FLY_RC##*/}"
for _fly_plugin in "$FLY_HOME/.fly.d/plugins"${_fly_p:-.d/*}/*.plugin."$_fly_shell" "$FLY_HOME/.fly.d/completions"/*."$_fly_shell"
do
    [ -r "$_fly_plugin" ] && . "$_fly_plugin"
done
unset _fly_p _fly_plugin _fly_shell
FLY_EOF

cat - <<'FLY_EOF' >$FLY_HOME/.fly.d/.fly.lib/.source_plugins.fish
set -l _fly_p ''
if test (count $argv) -gt 0
    set _fly_p "/$argv[1]"
end
set -l _fly_shell (string replace -r '^.*/' '' $FLY_SHELL)
set -e argv
test -r "$FLY_HOME/.fly.d/.$_fly_shell"rc && source "$FLY_HOME/.fly.d/.$_fly_shell"rc
if test -n "$_fly_p"
    for _fly_plugin in $FLY_HOME/.fly.d/plugins$_fly_p/conf.d/*.$_fly_shell
        set _fly_pdir (dirname (dirname $_fly_plugin))
        if test -r "$_fly_plugin"
            test -d "$_fly_pdir/functions"; and set -a fish_function_path "$_fly_pdir/functions"
            test -d "$_fly_pdir/completions"; and set -a fish_complete_path "$_fly_pdir/completions"
            source "$_fly_plugin"
        end
    end
else
    for _fly_plugin in $FLY_HOME/.fly.d/plugins.d/*/conf.d/*.$_fly_shell
        set _fly_pdir (dirname (dirname $_fly_plugin))
        if test -r "$_fly_plugin"
            test -d "$_fly_pdir/functions"; and set -a fish_function_path "$_fly_pdir/functions"
            test -d "$_fly_pdir/completions"; and set -a fish_complete_path "$_fly_pdir/completions"
            source "$_fly_plugin"
        end
    end
end
set -e _fly_p _fly_plugin _fly_shell _fly_pdir
